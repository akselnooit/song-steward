# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# vite
/dist/

# next.js (legacy — removed in v2 rebuild)
/.next/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel (legacy — now on GitHub Pages)
.vercel

# typescript
*.tsbuildinfo

# claude code
.claude/worktrees/
.claude/settings.local.json

# obsidian
.obsidian/

# data import scripts and source files
/data/

# database backups
/backups/

# supabase cli temp files
/supabase/.temp/
